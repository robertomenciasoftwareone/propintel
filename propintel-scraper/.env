# ─── Base de datos PostgreSQL ────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=propintel
DB_USER=propintel_user
DB_PASSWORD=local123

# ─── Azure Blob Storage (snapshots raw del scraping) ─────────────────────────
# Dejar vacío en local — se omite automáticamente
AZURE_STORAGE_CONNECTION_STRING=
AZURE_CONTAINER_NAME=propintel-snapshots

# ─── Email (alertas a usuarios) ───────────────────────────────────────────────
# En local puedes usar Mailtrap o dejar vacío para deshabilitar envíos
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_FROM=alertas@propintel.es

# ─── Scraping ─────────────────────────────────────────────────────────────────
SCRAPER_DELAY_SECONDS=2.5
SCRAPER_MAX_RETRIES=3
SCRAPER_TIMEOUT_SECONDS=30
HEADLESS_BROWSER=true

# ─── Scheduler ────────────────────────────────────────────────────────────────
SCRAPER_HORA_EJECUCION=07:00
